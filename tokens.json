      "inverse": "#FFFFFF"
    },
    "fill": {
      "brand": "#4C8BF5",
      "brandSoft": "#EAF2FF",
      "success": "#34C759",
      "warning": "#FFB340",
      "danger": "#FF6B6B",
      "neutralSoft": "#F1F3F5"
    },
    "tag": {
      "thought": {
        "bg": "#EEF3FB",
