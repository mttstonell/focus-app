      },
      "task": {
        "bg": "#EAF2FF",
        "text": "#3D73D1"
      },
      "emotion": {
        "bg": "#FFF1EC",
        "text": "#D97757"
      },
      "idea": {
        "bg": "#E8F8EF",
        "text": "#2E8B57"
      }
    }
  },
  "font": {
    "family": {
      "base": "SF Pro Text, PingFang SC, Helvetica Neue, Arial, sans-serif",
      "mono": "SFMono-Regular, Menlo, monospace"
    },
    "size": {
      "xs": 12,
      "sm": 14,
      "md": 16,
      "lg": 18,
      "xl": 20,
      "xxl": 24,
      "display": 32
    },
    "weight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "lineHeight": {
      "xs": 18,
      "sm": 20,
      "md": 24,
      "lg": 26,
      "xl": 30,
      "display": 38
    }
  },
  "textStyle": {
    "pageTitle": {
      "fontFamily": "SF Pro Text, PingFang SC, Helvetica Neue, Arial, sans-serif",
      "fontSize": 24,
      "fontWeight": 600,
      "lineHeight": 30
    },
    "sectionTitle": {
      "fontFamily": "SF Pro Text, PingFang SC, Helvetica Neue, Arial, sans-serif",
      "fontSize": 18,
      "fontWeight": 600,
      "lineHeight": 26
    },
    "cardTitle": {
      "fontFamily": "SF Pro Text, PingFang SC, Helvetica Neue, Arial, sans-serif",
      "fontSize": 16,
      "fontWeight": 600,
      "lineHeight": 24
    },
    "body": {
      "fontFamily": "SF Pro Text, PingFang SC, Helvetica Neue, Arial, sans-serif",
      "fontSize": 14,
      "fontWeight": 400,
      "lineHeight": 24
    },
    "caption": {
      "fontFamily": "SF Pro Text, PingFang SC, Helvetica Neue, Arial, sans-serif",
      "fontSize": 12,
      "fontWeight": 400,
      "lineHeight": 18
    },
    "statNumber": {
      "fontFamily": "SF Pro Text, PingFang SC, Helvetica Neue, Arial, sans-serif",
      "fontSize": 32,
      "fontWeight": 600,
      "lineHeight": 38
    }
  },
  "space": {
    "0": 0,
    "1": 4,
    "2": 8,
    "3": 12,
    "4": 16,
    "5": 20,
    "6": 24,
    "8": 32,
    "10": 40,
    "12": 48,
    "14": 56,
    "16": 64
  },
  "layout": {
    "pagePaddingX": 16,
    "pagePaddingTop": 20,
    "sectionGap": 24,
    "cardGap": 12,
    "inlineGap": 8,
    "chipGap": 8
  },
  "radius": {
    "none": 0,
    "sm": 8,
    "md": 12,
    "lg": 16,
    "xl": 20,
    "xxl": 24,
    "full": 999
  },
  "border": {
    "width": {
      "none": 0,
      "thin": 1,
      "medium": 2
    }
  },
  "shadow": {
    "sm": "0 2px 8px rgba(31,41,55,0.06)",
    "md": "0 8px 24px rgba(31,41,55,0.10)"
  },
  "motion": {
    "duration": {
      "fast": 120,
      "normal": 200,
      "slow": 280
    },
    "easing": {
      "standard": "cubic-bezier(0.2, 0, 0, 1)",
      "entrance": "cubic-bezier(0.16, 1, 0.3, 1)",
      "exit": "cubic-bezier(0.4, 0, 1, 1)"
    }
  },
  "opacity": {
    "disabled": 0.4,
    "muted": 0.64,
    "overlay": 0.32
  },
  "zIndex": {
    "base": 0,
    "sticky": 10,
    "floating": 20,
    "overlay": 30,
    "sheet": 40,
    "toast": 50
  },
  "icon": {
    "size": {
      "sm": 16,
      "md": 20,
      "lg": 24,
      "xl": 28
    }
  },
  "component": {
    "button": {
      "primary": {
        "height": 52,
        "paddingX": 16,
        "radius": 20,
        "bg": {
          "default": "#4C8BF5",
          "pressed": "#3D73D1",
          "disabled": "#D1D5DB"
        },
        "text": {
          "default": "#FFFFFF",
          "disabled": "#FFFFFF"
        }
      },
      "secondary": {
        "height": 44,
        "paddingX": 16,
        "radius": 16,
        "bg": {
          "default": "#FFFFFF",
          "pressed": "#F1F3F5",
          "disabled": "#F1F3F5"
        },
        "border": {
          "default": "#E5E7EB",
          "pressed": "#D1D5DB"
        },
        "text": {
          "default": "#1F2937",
          "disabled": "#6B7280"
        }
      },
      "ghost": {
        "height": 40,
        "paddingX": 12,
        "radius": 16,
        "text": {
          "default": "#4B5563",
          "pressed": "#1F2937"
        }
      }
    },
    "input": {
      "textArea": {
        "minHeight": 96,
        "padding": 16,
        "radius": 16,
        "bg": "#FFFFFF",
        "border": {
          "default": "#E5E7EB",
          "focus": "#8BB4FF",
          "error": "#FF6B6B"
        },
        "text": {
          "value": "#1F2937",
          "placeholder": "#6B7280"
        }
      }
    },
    "chip": {
      "height": 32,
      "paddingX": 12,
      "radius": 999,
      "textStyle": {
        "fontFamily": "SF Pro Text, PingFang SC, Helvetica Neue, Arial, sans-serif",
        "fontSize": 12,
        "fontWeight": 400,
        "lineHeight": 18
      },
      "default": {
        "bg": "#F1F3F5",
        "text": "#4B5563"
      },
      "selected": {
        "bg": "#EAF2FF",
        "text": "#4C8BF5",
        "border": "#8BB4FF"
      }
    },
    "card": {
      "default": {
        "bg": "#FFFFFF",
        "border": "#E5E7EB",
        "radius": 16,
        "padding": 16
      },
      "highlight": {
        "bg": "#EAF2FF",
        "border": "#8BB4FF",
        "radius": 16,
        "padding": 16
      }
    },
    "bottomSheet": {
      "bg": "#FFFFFF",
      "radiusTop": 24,
      "paddingTop": 12,
      "paddingX": 16,
      "paddingBottom": 24,
      "shadow": "0 8px 24px rgba(31,41,55,0.10)"
    },
    "segmentedControl": {
      "height": 36,
      "radius": 999,
      "bg": "#F1F3F5",
      "thumbBg": "#FFFFFF",
      "text": {
        "default": "#4B5563",
        "selected": "#1F2937"
      }
    },
    "toast": {
      "bg": "#1F2937",
      "text": "#FFFFFF",
      "radius": 16,
      "paddingX": 16,
      "paddingY": 12
    }
  },
  "page": {
    "home": {
      "bg": "#F7F8FA",
      "taskCard": "highlight",
      "pendingCard": "default",
      "primaryAction": "button.primary"
    },
    "quickNote": {
      "container": "bottomSheet",
      "input": "input.textArea",
      "quickAction": "chip",
      "primaryAction": "button.primary"
    },
    "inbox": {
      "bg": "#F7F8FA",
      "filter": "segmentedControl",
      "noteCard": "card.default",
      "primaryAction": "button.secondary"
    },
    "stats": {
      "bg": "#F7F8FA",
      "statNumber": "textStyle.statNumber",
      "chartCard": "card.default",
      "insightCard": "card.highlight"
    }
  }
}
